[project]
lang = "{{.Lang}}"
pkg = "{{.Pkg}}"

[paths]
spec = "{{.Spec}}"
output = "{{.Output}}"
# db_wrappers = ""

[commands]
gen = "./bin/shengen-codegen.sh"
build = "{{.Build}}"
test = "{{.Test}}"
shen_check = "{{.Check}}"
audit = "./bin/shenguard-audit.sh"

[engine]
relaxed = false

[[gates]]
name = "shengen"
kind = "command"
run  = "./bin/shengen-codegen.sh"

[[gates]]
name = "test"
kind = "command"
run  = "{{.Test}}"
parallel_group = "build-test"

[[gates]]
name = "build"
kind = "command"
run  = "{{.Build}}"
parallel_group = "build-test"

[[gates]]
name = "shen-check"
kind = "command"
run  = "{{.Check}}"

[[gates]]
name = "tcb-audit"
kind = "command"
run  = "./bin/shenguard-audit.sh"

[loop]
harness = "claude -p"
max_iter = 10
timeout = "10m"
prompt = "prompts/main_prompt.md"
plan = "plans/fix_plan.md"
