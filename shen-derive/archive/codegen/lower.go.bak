// Package codegen lowers shen-derive s-expression terms to Go source code.
// The lowering pattern-matches on s-expression structure: list combinators
// (map, foldr, foldl, scanl, filter) become for-loops; lambdas become
// closures; built-in operations map to Go operators.
package codegen

import (
	"fmt"
	"strings"

	"github.com/pyrex41/Shen-Backpressure/shen-derive/core"
)

// TypeMap provides Go type information for s-expression terms.
// Keys are Shen type expressions, values are Go type strings.
type TypeMap struct {
	// ParamTypes lists the Go types for function parameters, outermost first.
	ParamTypes []string
	// ResultType is the Go type for the function's return value.
	ResultType string
	// ElemType is the Go element type for list operations (e.g., "int" for []int).
	ElemType string
}

// LowerToGo produces a complete Go source file containing one function
// derived from the given s-expression term.
func LowerToGo(term core.Sexpr, tm *TypeMap, funcName, pkg string) (string, error) {
	cg := &codegen{counter: 0, tm: tm, varTypes: make(map[string]string)}

	funcCode, err := cg.genFunc(term, tm, funcName)
	if err != nil {
		return "", err
	}

	var buf strings.Builder
	fmt.Fprintf(&buf, "// Code generated by shen-derive. DO NOT EDIT.\n\n")
	fmt.Fprintf(&buf, "package %s\n", pkg)
	buf.WriteString(funcCode)
	buf.WriteString("\n")

	return buf.String(), nil
}

// LowerExprToGo produces just a Go expression string (no package wrapper).
func LowerExprToGo(term core.Sexpr) string {
	cg := &codegen{tm: &TypeMap{}, varTypes: make(map[string]string)}
	return cg.expr(term)
}

type codegen struct {
	counter  int
	tm       *TypeMap
	varTypes map[string]string // variable name → Go type
}

func (cg *codegen) fresh(prefix string) string {
	cg.counter++
	return fmt.Sprintf("_%s%d", prefix, cg.counter)
}

// --- Function generation ---

func (cg *codegen) genFunc(term core.Sexpr, tm *TypeMap, name string) (string, error) {
	type param struct {
		name string
		ty   string
	}

	var params []param
	curTerm := term
	paramIdx := 0

	// Peel off lambdas to extract parameters
	for {
		if paramIdx >= len(tm.ParamTypes) {
			break
		}
		if core.HeadSym(curTerm) == "lambda" {
			elems := core.ListElems(curTerm)
			if len(elems) != 3 {
				break
			}
			pname, ok := core.SymName(elems[1])
			if !ok {
				break
			}
			goName := goIdent(pname)
			goType := tm.ParamTypes[paramIdx]
			params = append(params, param{name: goName, ty: goType})
			cg.varTypes[goName] = goType
			curTerm = elems[2]
			paramIdx++
		} else {
			// Partially applied: synthesize parameter and extend the list.
			// E.g., (foldl + 0) with synthesized "xs" becomes (foldl + 0 xs),
			// not ((foldl + 0) xs), so the body recognizer sees the right shape.
			pname := cg.fresh("arg")
			params = append(params, param{name: pname, ty: tm.ParamTypes[paramIdx]})
			if elems := core.ListElems(curTerm); elems != nil {
				// Extend the existing list
				newElems := make([]core.Sexpr, len(elems)+1)
				copy(newElems, elems)
				newElems[len(elems)] = core.Sym(pname)
				curTerm = core.SList(newElems...)
			} else {
				// Atom being applied — wrap as application
				curTerm = core.SList(curTerm, core.Sym(pname))
			}
			paramIdx++
		}
	}

	retTy := tm.ResultType

	body, err := cg.body(curTerm, retTy)
	if err != nil {
		return "", err
	}

	var buf strings.Builder
	fmt.Fprintf(&buf, "\n// %s is derived by shen-derive.\n", name)

	pstrs := make([]string, len(params))
	for i, p := range params {
		pstrs[i] = p.name + " " + p.ty
	}
	fmt.Fprintf(&buf, "func %s(%s) %s {\n", name, strings.Join(pstrs, ", "), retTy)
	buf.WriteString(body)
	buf.WriteString("}\n")

	return buf.String(), nil
}

// body generates the statements inside a function body.
func (cg *codegen) body(term core.Sexpr, retTy string) (string, error) {
	head := core.HeadSym(term)
	elems := core.ListElems(term)

	// Projected foldl: (fst/snd (foldl step init list))
	if s, ok := cg.bodyProjectedFoldl(term); ok {
		return s, nil
	}

	// concat(map f list): concatMap
	if s, ok := cg.bodyConcatMap(term, retTy); ok {
		return s, nil
	}

	// map(f, filter(p, list)): fused map+filter
	if s, ok := cg.bodyMapAfterFilter(term, retTy); ok {
		return s, nil
	}

	// filter(p, map(f, list)): fused filter+map
	if s, ok := cg.bodyFilterAfterMap(term, retTy); ok {
		return s, nil
	}

	if head == "foldr" && len(elems) == 4 {
		return cg.bodyFoldr(elems[1], elems[2], elems[3], retTy), nil
	}
	if head == "foldl" && len(elems) == 4 {
		return cg.bodyFoldl(elems[1], elems[2], elems[3], retTy), nil
	}
	if head == "map" && len(elems) == 3 {
		if isNestedListProducer(elems[2]) {
			return "", fmt.Errorf("lower: unsupported nested pipeline shape %s", term)
		}
		return cg.bodyMap(elems[1], elems[2], retTy), nil
	}
	if head == "filter" && len(elems) == 3 {
		if isNestedListProducer(elems[2]) {
			return "", fmt.Errorf("lower: unsupported nested pipeline shape %s", term)
		}
		return cg.bodyFilter(elems[1], elems[2], retTy), nil
	}
	if head == "scanl" && len(elems) == 4 {
		return cg.bodyScanl(elems[1], elems[2], elems[3], retTy), nil
	}

	// If at top level
	if head == "if" && len(elems) == 4 {
		return cg.bodyIf(elems[1], elems[2], elems[3], retTy)
	}

	// Let binding
	if head == "let" && len(elems) == 4 {
		return cg.bodyLet(elems[1], elems[2], elems[3], retTy)
	}

	// Unsupported concat shape
	if head == "concat" && len(elems) == 2 {
		inner := elems[1]
		if core.HeadSym(inner) != "map" {
			return "", fmt.Errorf("lower: unsupported concat shape %s", term)
		}
	}

	// Unsupported nested pipeline
	if (head == "map" || head == "filter") && len(elems) == 3 {
		if isNestedListProducer(elems[2]) {
			return "", fmt.Errorf("lower: unsupported nested pipeline shape %s", term)
		}
	}

	// Default: return expression
	return "\treturn " + cg.expr(term) + "\n", nil
}

// --- Combinator body generators ---

func (cg *codegen) bodyFoldr(stepFn, initVal, list core.Sexpr, retTy string) string {
	xs := cg.fresh("xs")
	acc := cg.fresh("acc")
	idx := cg.fresh("i")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\t%s := %s\n", acc, cg.typedInitExpr(initVal, retTy))
	fmt.Fprintf(&buf, "\tfor %s := len(%s) - 1; %s >= 0; %s-- {\n", idx, xs, idx, idx)

	if body, elemVar, accVar, ok := uncurryLam2(stepFn); ok {
		fmt.Fprintf(&buf, "\t\t%s := %s[%s]\n", goIdent(elemVar), xs, idx)
		cg.genAssign(&buf, acc, body, goIdent(accVar), acc, goIdent(elemVar), goIdent(elemVar))
	} else if binOp := symBinOp(stepFn); binOp != "" {
		elem := cg.fresh("x")
		fmt.Fprintf(&buf, "\t\t%s := %s[%s]\n", elem, xs, idx)
		fmt.Fprintf(&buf, "\t\t%s = (%s %s %s)\n", acc, elem, binOp, acc)
	} else {
		elem := cg.fresh("x")
		fmt.Fprintf(&buf, "\t\t%s := %s[%s]\n", elem, xs, idx)
		fmt.Fprintf(&buf, "\t\t%s = %s(%s)(%s)\n", acc, cg.expr(stepFn), elem, acc)
	}

	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", acc)
	return buf.String()
}

func (cg *codegen) bodyFoldl(stepFn, initVal, list core.Sexpr, retTy string) string {
	xs := cg.fresh("xs")
	acc := cg.fresh("acc")
	elem := cg.fresh("x")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\t%s := %s\n", acc, cg.expr(initVal))
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)

	if body, accVar, elemVar, ok := uncurryLam2(stepFn); ok {
		cg.genAssign(&buf, acc, body, goIdent(accVar), acc, goIdent(elemVar), elem)
	} else if binOp := symBinOp(stepFn); binOp != "" {
		fmt.Fprintf(&buf, "\t\t%s = (%s %s %s)\n", acc, acc, binOp, elem)
	} else {
		fmt.Fprintf(&buf, "\t\t%s = %s(%s)(%s)\n", acc, cg.expr(stepFn), acc, elem)
	}

	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", acc)
	return buf.String()
}

func (cg *codegen) bodyProjectedFoldl(term core.Sexpr) (string, bool) {
	head := core.HeadSym(term)
	elems := core.ListElems(term)
	if (head != "fst" && head != "snd") || len(elems) != 2 {
		return "", false
	}

	inner := elems[1]
	innerHead := core.HeadSym(inner)
	innerElems := core.ListElems(inner)
	if innerHead != "foldl" || len(innerElems) != 4 {
		return "", false
	}

	stepFn, initVal, list := innerElems[1], innerElems[2], innerElems[3]

	xs := cg.fresh("xs")
	acc := cg.fresh("acc")
	elem := cg.fresh("x")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\t%s := %s\n", acc, cg.expr(initVal))
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)

	if body, accVar, elemVar, ok := uncurryLam2(stepFn); ok {
		cg.genAssign(&buf, acc, body, goIdent(accVar), acc, goIdent(elemVar), elem)
	} else if binOp := symBinOp(stepFn); binOp != "" {
		fmt.Fprintf(&buf, "\t\t%s = (%s %s %s)\n", acc, acc, binOp, elem)
	} else {
		fmt.Fprintf(&buf, "\t\t%s = %s(%s)(%s)\n", acc, cg.expr(stepFn), acc, elem)
	}

	fmt.Fprintf(&buf, "\t}\n")
	switch head {
	case "fst":
		fmt.Fprintf(&buf, "\treturn %s.Fst\n", acc)
	default:
		fmt.Fprintf(&buf, "\treturn %s.Snd\n", acc)
	}
	return buf.String(), true
}

func (cg *codegen) bodyMap(fn, list core.Sexpr, retTy string) string {
	xs := cg.fresh("xs")
	result := cg.fresh("result")
	idx := cg.fresh("i")
	elem := cg.fresh("x")

	// Register element type for the loop variable
	elemTy := sliceElemType(retTy)
	cg.varTypes[elem] = elemTy

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\t%s := make(%s, len(%s))\n", result, retTy, xs)
	fmt.Fprintf(&buf, "\tfor %s, %s := range %s {\n", idx, elem, xs)

	if body, paramVar, ok := uncurryLam1(fn); ok {
		// Register the lambda param as having the element type
		cg.varTypes[goIdent(paramVar)] = elemTy
		fmt.Fprintf(&buf, "\t\t%s[%s] = %s\n", result, idx,
			cg.exprSubst(body, map[string]string{goIdent(paramVar): elem}))
	} else {
		fmt.Fprintf(&buf, "\t\t%s[%s] = %s\n", result, idx, cg.appliedExpr(fn, elem))
	}

	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String()
}

func (cg *codegen) bodyFilter(pred, list core.Sexpr, retTy string) string {
	xs := cg.fresh("xs")
	result := cg.fresh("result")
	elem := cg.fresh("x")

	elemTy := sliceElemType(retTy)
	cg.varTypes[elem] = elemTy

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\tvar %s %s\n", result, retTy)
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)

	if body, paramVar, ok := uncurryLam1(pred); ok {
		cg.varTypes[goIdent(paramVar)] = elemTy
		fmt.Fprintf(&buf, "\t\tif %s {\n",
			cg.exprSubst(body, map[string]string{goIdent(paramVar): elem}))
	} else {
		fmt.Fprintf(&buf, "\t\tif %s {\n", cg.appliedExpr(pred, elem))
	}

	fmt.Fprintf(&buf, "\t\t\t%s = append(%s, %s)\n", result, result, elem)
	fmt.Fprintf(&buf, "\t\t}\n")
	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String()
}

func (cg *codegen) bodyScanl(stepFn, initVal, list core.Sexpr, retTy string) string {
	xs := cg.fresh("xs")
	acc := cg.fresh("acc")
	result := cg.fresh("result")
	elem := cg.fresh("x")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\t%s := %s\n", acc, cg.expr(initVal))
	fmt.Fprintf(&buf, "\t%s := make(%s, 0, len(%s)+1)\n", result, retTy, xs)
	fmt.Fprintf(&buf, "\t%s = append(%s, %s)\n", result, result, acc)
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)

	if body, accVar, elemVar, ok := uncurryLam2(stepFn); ok {
		cg.genAssign(&buf, acc, body, goIdent(accVar), acc, goIdent(elemVar), elem)
	} else if binOp := symBinOp(stepFn); binOp != "" {
		fmt.Fprintf(&buf, "\t\t%s = (%s %s %s)\n", acc, acc, binOp, elem)
	} else {
		fmt.Fprintf(&buf, "\t\t%s = %s(%s)(%s)\n", acc, cg.expr(stepFn), acc, elem)
	}

	fmt.Fprintf(&buf, "\t\t%s = append(%s, %s)\n", result, result, acc)
	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String()
}

func (cg *codegen) bodyConcatMap(term core.Sexpr, retTy string) (string, bool) {
	head := core.HeadSym(term)
	elems := core.ListElems(term)
	if head != "concat" || len(elems) != 2 {
		return "", false
	}

	inner := elems[1]
	innerHead := core.HeadSym(inner)
	innerElems := core.ListElems(inner)
	if innerHead != "map" || len(innerElems) != 3 {
		return "", false
	}

	fn, list := innerElems[1], innerElems[2]

	xs := cg.fresh("xs")
	result := cg.fresh("result")
	elem := cg.fresh("x")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\tvar %s %s\n", result, retTy)
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)
	fmt.Fprintf(&buf, "\t\t%s = append(%s, %s...)\n", result, result, cg.appliedExpr(fn, elem))
	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String(), true
}

func (cg *codegen) bodyMapAfterFilter(term core.Sexpr, retTy string) (string, bool) {
	head := core.HeadSym(term)
	elems := core.ListElems(term)
	if head != "map" || len(elems) != 3 {
		return "", false
	}

	fn := elems[1]
	inner := elems[2]
	innerHead := core.HeadSym(inner)
	innerElems := core.ListElems(inner)
	if innerHead != "filter" || len(innerElems) != 3 {
		return "", false
	}

	pred, list := innerElems[1], innerElems[2]

	xs := cg.fresh("xs")
	result := cg.fresh("result")
	elem := cg.fresh("x")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\tvar %s %s\n", result, retTy)
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)
	fmt.Fprintf(&buf, "\t\tif %s {\n", cg.appliedExpr(pred, elem))
	fmt.Fprintf(&buf, "\t\t\t%s = append(%s, %s)\n", result, result, cg.appliedExpr(fn, elem))
	fmt.Fprintf(&buf, "\t\t}\n")
	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String(), true
}

func (cg *codegen) bodyFilterAfterMap(term core.Sexpr, retTy string) (string, bool) {
	head := core.HeadSym(term)
	elems := core.ListElems(term)
	if head != "filter" || len(elems) != 3 {
		return "", false
	}

	pred := elems[1]
	inner := elems[2]
	innerHead := core.HeadSym(inner)
	innerElems := core.ListElems(inner)
	if innerHead != "map" || len(innerElems) != 3 {
		return "", false
	}

	fn, list := innerElems[1], innerElems[2]

	xs := cg.fresh("xs")
	result := cg.fresh("result")
	elem := cg.fresh("x")
	mapped := cg.fresh("mapped")

	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", xs, cg.expr(list))
	fmt.Fprintf(&buf, "\tvar %s %s\n", result, retTy)
	fmt.Fprintf(&buf, "\tfor _, %s := range %s {\n", elem, xs)
	fmt.Fprintf(&buf, "\t\t%s := %s\n", mapped, cg.appliedExpr(fn, elem))
	fmt.Fprintf(&buf, "\t\tif %s {\n", cg.appliedExpr(pred, mapped))
	fmt.Fprintf(&buf, "\t\t\t%s = append(%s, %s)\n", result, result, mapped)
	fmt.Fprintf(&buf, "\t\t}\n")
	fmt.Fprintf(&buf, "\t}\n")
	fmt.Fprintf(&buf, "\treturn %s\n", result)
	return buf.String(), true
}

func (cg *codegen) bodyIf(cond, then, els core.Sexpr, retTy string) (string, error) {
	var buf strings.Builder
	fmt.Fprintf(&buf, "\tif %s {\n", cg.expr(cond))
	thenBody, err := cg.body(then, retTy)
	if err != nil {
		return "", err
	}
	buf.WriteString(thenBody)
	fmt.Fprintf(&buf, "\t} else {\n")
	elseBody, err := cg.body(els, retTy)
	if err != nil {
		return "", err
	}
	buf.WriteString(elseBody)
	fmt.Fprintf(&buf, "\t}\n")
	return buf.String(), nil
}

func (cg *codegen) bodyLet(nameExpr, bound, bodyExpr core.Sexpr, retTy string) (string, error) {
	name, ok := core.SymName(nameExpr)
	if !ok {
		return "", fmt.Errorf("let: name must be a symbol, got %s", nameExpr)
	}
	var buf strings.Builder
	fmt.Fprintf(&buf, "\t%s := %s\n", goIdent(name), cg.expr(bound))
	b, err := cg.body(bodyExpr, retTy)
	if err != nil {
		return "", err
	}
	buf.WriteString(b)
	return buf.String(), nil
}

// --- Expression generation ---

func (cg *codegen) expr(s core.Sexpr) string {
	return cg.exprSubst(s, nil)
}

func (cg *codegen) exprSubst(s core.Sexpr, subst map[string]string) string {
	switch s := s.(type) {
	case *core.Atom:
		switch s.Kind {
		case core.AtomInt:
			return s.Val
		case core.AtomBool:
			return s.Val
		case core.AtomString:
			return fmt.Sprintf("%q", s.Val)
		case core.AtomSymbol:
			name := goIdent(s.Val)
			if subst != nil {
				if sub, ok := subst[name]; ok {
					return sub
				}
			}
			// Built-in operators as function values
			if binOp := symBinOp(s); binOp != "" {
				return cg.primFuncExpr(s.Val)
			}
			return name
		}

	case *core.List:
		if len(s.Elems) == 0 {
			return "nil"
		}

		head := core.HeadSym(s)

		// Lambda → Go closure
		if head == "lambda" && len(s.Elems) == 3 {
			param, _ := core.SymName(s.Elems[1])
			bodySubst := copySubst(subst)
			delete(bodySubst, goIdent(param))
			body := cg.exprSubst(s.Elems[2], bodySubst)
			paramTy := cg.guessParamType(s.Elems[2], param)
			retTy := cg.guessExprType(s.Elems[2])
			return fmt.Sprintf("func(%s %s) %s { return %s }", goIdent(param), paramTy, retTy, body)
		}

		// Let → IIFE
		if head == "let" && len(s.Elems) == 4 {
			name, _ := core.SymName(s.Elems[1])
			val := cg.exprSubst(s.Elems[2], subst)
			newSubst := copySubst(subst)
			v := cg.fresh("v")
			newSubst[goIdent(name)] = v
			body := cg.exprSubst(s.Elems[3], newSubst)
			retTy := cg.guessExprType(s.Elems[3])
			return fmt.Sprintf("func() %s { %s := %s; return %s }()", retTy, v, val, body)
		}

		// If → ternary-like IIFE
		if head == "if" && len(s.Elems) == 4 {
			cond := cg.exprSubst(s.Elems[1], subst)
			then := cg.exprSubst(s.Elems[2], subst)
			els := cg.exprSubst(s.Elems[3], subst)
			retTy := cg.guessExprType(s.Elems[2])
			return fmt.Sprintf("func() %s { if %s { return %s }; return %s }()", retTy, cond, then, els)
		}

		// Tuple
		if head == "@p" && len(s.Elems) == 3 {
			fst := cg.exprSubst(s.Elems[1], subst)
			snd := cg.exprSubst(s.Elems[2], subst)
			fstTy := cg.guessExprType(s.Elems[1])
			sndTy := cg.guessExprType(s.Elems[2])
			return fmt.Sprintf("struct{ Fst %s; Snd %s }{%s, %s}", fstTy, sndTy, fst, snd)
		}

		// Unary operations
		if head == "fst" && len(s.Elems) == 2 {
			return cg.exprSubst(s.Elems[1], subst) + ".Fst"
		}
		if head == "snd" && len(s.Elems) == 2 {
			return cg.exprSubst(s.Elems[1], subst) + ".Snd"
		}
		if head == "not" && len(s.Elems) == 2 {
			return "(!" + cg.exprSubst(s.Elems[1], subst) + ")"
		}

		// Binary operations: (+ a b), (>= a b), etc.
		if len(s.Elems) == 3 {
			if goOp := symBinOp(s.Elems[0]); goOp != "" {
				lhs := cg.exprSubst(s.Elems[1], subst)
				rhs := cg.exprSubst(s.Elems[2], subst)
				return fmt.Sprintf("(%s %s %s)", lhs, goOp, rhs)
			}
		}

		// cons x xs → append([]T{x}, xs...)
		if head == "cons" && len(s.Elems) == 3 {
			elem := cg.exprSubst(s.Elems[1], subst)
			list := cg.exprSubst(s.Elems[2], subst)
			elemTy := cg.guessExprType(s.Elems[1])
			return fmt.Sprintf("append([]%s{%s}, %s...)", elemTy, elem, list)
		}

		// nil as typed empty slice
		if head == "nil" && len(s.Elems) == 1 {
			return "nil"
		}

		// Compose: (compose f g x) → f(g(x)), (compose f g) → func(x) { return f(g(x)) }
		if head == "compose" && len(s.Elems) == 4 {
			f := cg.exprSubst(s.Elems[1], subst)
			gx := cg.exprSubst(core.SList(s.Elems[2], s.Elems[3]), subst)
			return fmt.Sprintf("%s(%s)", f, gx)
		}

		// Beta-reduce: ((lambda X body) arg ...) → body[X/arg] applied to remaining args
		if core.HeadSym(s.Elems[0]) == "lambda" && len(s.Elems) >= 2 {
			lamElems := core.ListElems(s.Elems[0])
			if len(lamElems) == 3 {
				param, _ := core.SymName(lamElems[1])
				bodySubst := copySubst(subst)
				bodySubst[goIdent(param)] = cg.exprSubst(s.Elems[1], subst)
				reducedBody := lamElems[2]
				if len(s.Elems) == 2 {
					return cg.exprSubst(reducedBody, bodySubst)
				}
				// More args remain: construct (body arg2 arg3 ...) and recurse
				remaining := make([]core.Sexpr, 0, len(s.Elems)-1)
				remaining = append(remaining, reducedBody)
				remaining = append(remaining, s.Elems[2:]...)
				return cg.exprSubst(core.SList(remaining...), bodySubst)
			}
		}

		// Generic function application
		fn := cg.exprSubst(s.Elems[0], subst)
		args := make([]string, len(s.Elems)-1)
		for i, a := range s.Elems[1:] {
			args[i] = cg.exprSubst(a, subst)
		}
		// Curried application: f(a)(b)(c)
		result := fn
		for _, arg := range args {
			result = fmt.Sprintf("%s(%s)", result, arg)
		}
		return result
	}

	return fmt.Sprintf("/* TODO: %T */", s)
}

// genAssign generates an assignment statement for acc inside a loop body.
func (cg *codegen) genAssign(buf *strings.Builder, accVar string, bodyTerm core.Sexpr, accOld, accNew, elemOld, elemNew string) {
	subst := map[string]string{accOld: accNew, elemOld: elemNew}

	// If the body is (if cond then else), generate clean if/else
	if core.HeadSym(bodyTerm) == "if" {
		elems := core.ListElems(bodyTerm)
		if len(elems) == 4 {
			cond := cg.exprSubst(elems[1], subst)
			thenExpr := cg.exprSubst(elems[2], subst)
			elseExpr := cg.exprSubst(elems[3], subst)

			if thenExpr == accNew {
				fmt.Fprintf(buf, "\t\tif !(%s) {\n", cond)
				fmt.Fprintf(buf, "\t\t\t%s = %s\n", accVar, elseExpr)
				fmt.Fprintf(buf, "\t\t}\n")
				return
			}
			if elseExpr == accNew {
				fmt.Fprintf(buf, "\t\tif %s {\n", cond)
				fmt.Fprintf(buf, "\t\t\t%s = %s\n", accVar, thenExpr)
				fmt.Fprintf(buf, "\t\t}\n")
				return
			}

			fmt.Fprintf(buf, "\t\tif %s {\n", cond)
			fmt.Fprintf(buf, "\t\t\t%s = %s\n", accVar, thenExpr)
			fmt.Fprintf(buf, "\t\t} else {\n")
			fmt.Fprintf(buf, "\t\t\t%s = %s\n", accVar, elseExpr)
			fmt.Fprintf(buf, "\t\t}\n")
			return
		}
	}

	fmt.Fprintf(buf, "\t\t%s = %s\n", accVar, cg.exprSubst(bodyTerm, subst))
}

func (cg *codegen) appliedExpr(fn core.Sexpr, argName string) string {
	if body, paramVar, ok := uncurryLam1(fn); ok {
		return cg.exprSubst(body, map[string]string{goIdent(paramVar): argName})
	}
	// Handle (compose f g) applied to arg → f(g(arg))
	if core.HeadSym(fn) == "compose" {
		elems := core.ListElems(fn)
		if len(elems) == 3 {
			return cg.expr(core.SList(elems[1], core.SList(elems[2], core.Sym(argName))))
		}
	}
	return cg.expr(core.SList(fn, core.Sym(argName)))
}

// --- Helpers ---

func uncurryLam2(s core.Sexpr) (body core.Sexpr, param1, param2 string, ok bool) {
	if core.HeadSym(s) != "lambda" {
		return nil, "", "", false
	}
	elems := core.ListElems(s)
	if len(elems) != 3 {
		return nil, "", "", false
	}
	p1, ok1 := core.SymName(elems[1])
	if !ok1 {
		return nil, "", "", false
	}
	inner := elems[2]
	if core.HeadSym(inner) != "lambda" {
		return nil, "", "", false
	}
	innerElems := core.ListElems(inner)
	if len(innerElems) != 3 {
		return nil, "", "", false
	}
	p2, ok2 := core.SymName(innerElems[1])
	if !ok2 {
		return nil, "", "", false
	}
	return innerElems[2], p1, p2, true
}

func uncurryLam1(s core.Sexpr) (body core.Sexpr, param string, ok bool) {
	if core.HeadSym(s) != "lambda" {
		return nil, "", false
	}
	elems := core.ListElems(s)
	if len(elems) != 3 {
		return nil, "", false
	}
	p, ok1 := core.SymName(elems[1])
	if !ok1 {
		return nil, "", false
	}
	return elems[2], p, true
}

// symBinOp returns the Go binary operator for a symbol, or "".
func symBinOp(s core.Sexpr) string {
	name, ok := core.SymName(s)
	if !ok {
		return ""
	}
	switch name {
	case "+":
		return "+"
	case "-":
		return "-"
	case "*":
		return "*"
	case "/":
		return "/"
	case "%":
		return "%"
	case "=":
		return "=="
	case "!=":
		return "!="
	case "<":
		return "<"
	case "<=":
		return "<="
	case ">":
		return ">"
	case ">=":
		return ">="
	case "and":
		return "&&"
	case "or":
		return "||"
	}
	return ""
}

func (cg *codegen) primFuncExpr(op string) string {
	switch op {
	case "+":
		return "func(a, b int) int { return a + b }"
	case "-":
		return "func(a, b int) int { return a - b }"
	case "*":
		return "func(a, b int) int { return a * b }"
	case "nil":
		return "nil"
	default:
		return fmt.Sprintf("/* prim:%s */", op)
	}
}

func goIdent(name string) string {
	if len(name) == 0 {
		return name
	}
	name = strings.ReplaceAll(name, "'", "_p")
	name = strings.ReplaceAll(name, "-", "_")
	return name
}

func (cg *codegen) guessExprType(s core.Sexpr) string {
	switch s := s.(type) {
	case *core.Atom:
		switch s.Kind {
		case core.AtomInt:
			return "int"
		case core.AtomBool:
			return "bool"
		case core.AtomString:
			return "string"
		case core.AtomSymbol:
			if t, ok := cg.varTypes[goIdent(s.Val)]; ok {
				return t
			}
			return "int" // default for variables in arithmetic contexts
		}
	case *core.List:
		head := core.HeadSym(s)
		switch head {
		case "+", "-", "*", "/", "%":
			return "int"
		case "=", "!=", "<", "<=", ">", ">=", "and", "or", "not":
			return "bool"
		case "if":
			if len(s.Elems) >= 3 {
				return cg.guessExprType(s.Elems[2])
			}
		case "@p":
			if len(s.Elems) == 3 {
				fstTy := cg.guessExprType(s.Elems[1])
				sndTy := cg.guessExprType(s.Elems[2])
				return fmt.Sprintf("struct{ Fst %s; Snd %s }", fstTy, sndTy)
			}
		case "fst":
			return "int" // best guess
		case "snd":
			return "bool" // common in projected foldl patterns
		case "let":
			if len(s.Elems) == 4 {
				return cg.guessExprType(s.Elems[3])
			}
		case "lambda":
			return cg.guessClosureType(s)
		case "cons":
			if len(s.Elems) == 3 {
				return "[]" + cg.guessExprType(s.Elems[1])
			}
		}
		// Lambda application: ((lambda X body) arg ...) → guess type of body
		if core.HeadSym(s.Elems[0]) == "lambda" && len(s.Elems) >= 2 {
			lamElems := core.ListElems(s.Elems[0])
			if len(lamElems) == 3 {
				// For single-arg application, look at the lambda body
				if len(s.Elems) == 2 {
					return cg.guessExprType(lamElems[2])
				}
				// Multi-arg: the body is itself a lambda; recurse
				remaining := make([]core.Sexpr, 0, len(s.Elems)-1)
				remaining = append(remaining, lamElems[2])
				remaining = append(remaining, s.Elems[2:]...)
				return cg.guessExprType(core.SList(remaining...))
			}
		}
	}
	return "int"
}

func (cg *codegen) guessParamType(body core.Sexpr, paramName string) string {
	// Check if we know this variable's type
	if t, ok := cg.varTypes[goIdent(paramName)]; ok {
		return t
	}
	// Infer from the result type of the body expression
	return cg.guessExprType(body)
}

func (cg *codegen) guessClosureType(s core.Sexpr) string {
	elems := core.ListElems(s)
	if len(elems) != 3 {
		return "func(int) int"
	}
	bodyTy := cg.guessExprType(elems[2])
	return fmt.Sprintf("func(int) %s", bodyTy)
}

func copySubst(s map[string]string) map[string]string {
	out := make(map[string]string)
	if s != nil {
		for k, v := range s {
			out[k] = v
		}
	}
	return out
}

// sliceElemType extracts the element type from a Go slice type string.
// E.g., "[]int" → "int", "[]bool" → "bool".
func sliceElemType(sliceTy string) string {
	if strings.HasPrefix(sliceTy, "[]") {
		return sliceTy[2:]
	}
	return "int"
}

// typedInitExpr generates the init value expression, adding a type cast
// for nil to avoid Go's "use of untyped nil" errors.
func (cg *codegen) typedInitExpr(initVal core.Sexpr, retTy string) string {
	if core.IsSym(initVal, "nil") {
		return fmt.Sprintf("%s(nil)", retTy)
	}
	return cg.expr(initVal)
}

func isNestedListProducer(s core.Sexpr) bool {
	head := core.HeadSym(s)
	switch head {
	case "map", "filter", "concat":
		return true
	case "foldr", "foldl", "scanl":
		return true
	}
	return false
}
