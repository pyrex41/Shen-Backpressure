	targets := phase10ExpansionTargets()
	if got := len(targets); got != 2 {
		t.Fatalf("phase 10 expansion drift: got %d targets, want 2", got)
	}

	for _, target := range targets {
		t.Run(target.name, func(t *testing.T) {
